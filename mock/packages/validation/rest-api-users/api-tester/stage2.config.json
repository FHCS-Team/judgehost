{
  "container_id": "api-tester",
  "accepts_submission": false,
  "network": {
    "enabled": false,
    "internal_only": true,
    "network_name": "eval-network-{{submission_id}}",
    "allowed_containers": ["submission"]
  },
  "resource_limits": {
    "cpu": "0.5",
    "memory": "256M",
    "timeout": 300
  },
  "environment": {
    "API_BASE_URL": "http://submission:3000",
    "TEST_TIMEOUT": "5000"
  }
}
