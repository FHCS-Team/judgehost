{
  "problem_id": "rest-api-users",
  "name": "REST API - User Management",
  "description": "Build a REST API for user management with CRUD operations and database integration",
  "project_type": "web-api",
  "difficulty": "medium",
  "time_limit": 300,

  "containers": [
    {
      "container_id": "database",
      "name": "PostgreSQL Database",
      "accepts_submission": false,
      "dockerfile_path": "database/Dockerfile",
      "depends_on": []
    },
    {
      "container_id": "submission",
      "name": "Submission API",
      "accepts_submission": true,
      "dockerfile_path": "submission/Dockerfile",
      "depends_on": [
        {
          "container_id": "database",
          "condition": "healthy",
          "timeout": 30,
          "retry": 5,
          "retry_interval": 2
        }
      ]
    },
    {
      "container_id": "api-tester",
      "name": "API Test Runner",
      "accepts_submission": false,
      "dockerfile_path": "api-tester/Dockerfile",
      "depends_on": [
        {
          "container_id": "submission",
          "condition": "healthy",
          "timeout": 30,
          "retry": 5,
          "retry_interval": 2
        }
      ],
      "terminate_on_finish": ["submission", "database"]
    }
  ],

  "rubrics": [
    {
      "rubric_id": "api_endpoints",
      "name": "API Endpoints",
      "type": "api_endpoints",
      "max_score": 60,
      "evaluated_by_container": "api-tester"
    },
    {
      "rubric_id": "code_quality",
      "name": "Code Quality",
      "type": "code_quality",
      "max_score": 20,
      "evaluated_by_container": "submission"
    },
    {
      "rubric_id": "security",
      "name": "Security",
      "type": "security_scan",
      "max_score": 20,
      "evaluated_by_container": "submission"
    }
  ]
}
