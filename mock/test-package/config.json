{
  "problem_id": "reverse-string",
  "problem_name": "Reverse String",
  "description": "Write a function that reverses a string",
  "project_type": "nodejs",
  "timeout": 300,
  "submission_packages": [
    {
      "package_id": "main",
      "target_container": "submission",
      "required": true
    }
  ],
  "containers": [
    {
      "container_id": "submission",
      "accepts_submission": true,
      "submission_package_id": "main",
      "image_name": "judgehost-reverse-string-submission:latest",
      "dockerfile_path": "./submission/Dockerfile",
      "stages": [
        {
          "stage_id": "stage1_build",
          "name": "Build Stage",
          "working_directory": "/workspace",
          "command": "npm install",
          "timeout": 60,
          "network_enabled": true,
          "resource_limits": {
            "memory_limit": "512m",
            "cpu_limit": "1.0"
          }
        },
        {
          "stage_id": "stage2_test",
          "name": "Test Stage",
          "working_directory": "/workspace",
          "command": "npm test",
          "timeout": 120,
          "network_enabled": false,
          "resource_limits": {
            "memory_limit": "512m",
            "cpu_limit": "1.0"
          }
        }
      ]
    }
  ],
  "rubrics": [
    {
      "rubric_id": "rubric_1_test_cases",
      "name": "Test Cases",
      "type": "test_cases",
      "max_score": 80,
      "evaluated_by_container": "submission",
      "evaluated_by_hook": "post_01_run_tests.sh"
    },
    {
      "rubric_id": "rubric_2_code_quality",
      "name": "Code Quality",
      "type": "code_quality",
      "max_score": 20,
      "evaluated_by_container": "submission",
      "evaluated_by_hook": "post_02_code_quality.sh"
    }
  ]
}
