#!/bin/bash
# Post-hook: Test the API endpoints

set -e

# Ensure PATH includes standard utilities
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

echo "[POST] Testing Node.js API endpoints..."

API_URL="http://localhost:3000"
TEST_CASES="$PROBLEM_DIR/data/test_cases.json"
RESULTS_FILE="$OUT_DIR/test_results.json"
RUBRIC_FILE="$OUT_DIR/result.json"

# Wait for server to be ready
echo "[POST] Waiting for server to be ready..."
MAX_RETRIES=30
RETRY_COUNT=0

while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
    if /usr/bin/curl -s -f "$API_URL/health" > /dev/null 2>&1; then
        echo "[POST] Server is ready!"
        break
    fi
    RETRY_COUNT=$((RETRY_COUNT + 1))
    sleep 1
done

if [ $RETRY_COUNT -eq $MAX_RETRIES ]; then
    echo "[POST ERROR] Server failed to start within timeout"
    cat > "$RUBRIC_FILE" <<EOF
{
  "rubric_id": "functionality",
  "score": 0,
  "max_score": 50,
  "passed": false,
  "feedback": "Server failed to start"
}
EOF
    exit 0
fi

# Run tests
echo "[POST] Running API tests..."

PASSED=0
FAILED=0
TOTAL=0
declare -A SAVED_IDS

# Read and execute test cases
while IFS= read -r test_case; do
    NAME=$(echo "$test_case" | /usr/bin/jq -r '.name')
    METHOD=$(echo "$test_case" | /usr/bin/jq -r '.method')
    PATH=$(echo "$test_case" | /usr/bin/jq -r '.path')
    EXPECTED_STATUS=$(echo "$test_case" | /usr/bin/jq -r '.expectedStatus')
    BODY=$(echo "$test_case" | /usr/bin/jq -r '.body // empty')
    SAVE_ID=$(echo "$test_case" | /usr/bin/jq -r '.saveId // empty')
    
    # Replace placeholders with saved IDs
    for key in "${!SAVED_IDS[@]}"; do
        PATH="${PATH//\{$key\}/${SAVED_IDS[$key]}}"
    done
    
    TOTAL=$((TOTAL + 1))
    
    echo "[TEST] $NAME"
    
    # Make request
    if [ -n "$BODY" ] && [ "$BODY" != "null" ]; then
        RESPONSE=$(/usr/bin/curl -s -w "\n%{http_code}" -X "$METHOD" \
            -H "Content-Type: application/json" \
            -d "$BODY" \
            "$API_URL$PATH")
    else
        RESPONSE=$(/usr/bin/curl -s -w "\n%{http_code}" -X "$METHOD" "$API_URL$PATH")
    fi
    
    HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
    RESPONSE_BODY=$(echo "$RESPONSE" | sed '$d')
    
    # Check status code
    if [ "$HTTP_CODE" = "$EXPECTED_STATUS" ]; then
        echo "[TEST] ✓ Status code: $HTTP_CODE"
        PASSED=$((PASSED + 1))
        
        # Save ID if requested
        if [ -n "$SAVE_ID" ] && [ "$SAVE_ID" != "null" ]; then
            ID=$(echo "$RESPONSE_BODY" | /usr/bin/jq -r '.data.id // empty')
            if [ -n "$ID" ]; then
                SAVED_IDS[$SAVE_ID]="$ID"
                echo "[TEST] Saved ID: $SAVE_ID = $ID"
            fi
        fi
    else
        echo "[TEST] ✗ Status code: expected $EXPECTED_STATUS, got $HTTP_CODE"
        FAILED=$((FAILED + 1))
    fi
    
done < <(/usr/bin/jq -c '.[]' "$TEST_CASES")

echo "[POST] Tests completed: $PASSED passed, $FAILED failed out of $TOTAL"

# Calculate scores
FUNCTIONALITY_SCORE=$(( PASSED * 50 / TOTAL ))
VALIDATION_SCORE=$(( PASSED >= 9 ? 30 : PASSED * 30 / TOTAL ))

# Write rubric results
cat > "$RUBRIC_FILE" <<EOF
{
  "rubric_id": "functionality",
  "score": $FUNCTIONALITY_SCORE,
  "max_score": 50,
  "passed": $([ $FAILED -eq 0 ] && echo "true" || echo "false"),
  "feedback": "Passed $PASSED out of $TOTAL tests",
  "details": {
    "total_tests": $TOTAL,
    "passed": $PASSED,
    "failed": $FAILED
  }
}
EOF

cat > "$OUT_DIR/validation_result.json" <<EOF
{
  "rubric_id": "data_validation",
  "score": $VALIDATION_SCORE,
  "max_score": 30,
  "passed": $([ $VALIDATION_SCORE -ge 20 ] && echo "true" || echo "false"),
  "feedback": "Input validation checks"
}
EOF

echo "[POST] Test results written to $RUBRIC_FILE"
exit 0
