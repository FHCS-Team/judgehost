{
  "problem_id": "api-with-redis",
  "problem_name": "REST API with Redis Cache",
  "description": "Build a REST API that uses Redis for caching frequently accessed data",
  "project_type": "web_api",
  "container_type": "multi-container",

  "containers": [
    {
      "container_id": "redis",
      "container_name": "Redis Cache",
      "role": "cache",
      "base_image": "redis:7-alpine",
      "accepts_submission": false,
      "environment": {},
      "resource_limits": {
        "memory": "128m",
        "cpus": 0.5
      },
      "network_mode": "internal",
      "ports": ["6379"],
      "command": "redis-server --maxmemory 100mb --maxmemory-policy allkeys-lru",
      "health_check": {
        "command": "redis-cli ping | grep PONG",
        "interval": 5,
        "timeout": 3,
        "retries": 3
      }
    },
    {
      "container_id": "api",
      "container_name": "API Server",
      "role": "submission",
      "base_image": "python:3.11-slim",
      "accepts_submission": true,
      "submission_package_id": "api",
      "mount_path": "/app",
      "build_steps": [
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "copy",
          "source": "requirements.txt",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "pip install --no-cache-dir -r requirements.txt"
        },
        {
          "type": "copy",
          "source": ".",
          "destination": "./"
        }
      ],
      "environment": {
        "REDIS_HOST": "redis",
        "REDIS_PORT": "6379",
        "PORT": "8000"
      },
      "resource_limits": {
        "memory": "512m",
        "cpus": 1.0,
        "timeout": 120
      },
      "network_mode": "internal",
      "ports": ["8000"],
      "depends_on": ["redis"],
      "command": "python app.py",
      "health_check": {
        "command": "curl -f http://localhost:8000/health || exit 1",
        "interval": 10,
        "timeout": 5,
        "retries": 3
      }
    },
    {
      "container_id": "test_runner",
      "container_name": "API Test Suite",
      "role": "sidecar",
      "base_image": "python:3.11-slim",
      "accepts_submission": false,
      "build_steps": [
        {
          "type": "workdir",
          "path": "/tests"
        },
        {
          "type": "copy",
          "source": ".",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "pip install --no-cache-dir pytest requests redis"
        }
      ],
      "environment": {
        "API_BASE_URL": "http://api:8000",
        "REDIS_HOST": "redis",
        "REDIS_PORT": "6379"
      },
      "resource_limits": {
        "memory": "256m",
        "cpus": 0.5,
        "timeout": 60
      },
      "network_mode": "internal",
      "depends_on": ["api", "redis"],
      "command": "pytest -v --tb=short --json-report --json-report-file=/out/test_results.json"
    }
  ],

  "submission_packages": [
    {
      "package_id": "api",
      "package_name": "API Implementation",
      "target_container_id": "api",
      "mount_path": "/app",
      "required": true
    }
  ],

  "resource_limits": {
    "memory": "1g",
    "cpus": 2,
    "timeout": 120
  },

  "rubrics": [
    {
      "rubric_id": "api_endpoints",
      "rubric_name": "API Endpoints",
      "rubric_type": "numeric",
      "max_score": 40,
      "weight": 1.0,
      "description": "All required endpoints implemented and working"
    },
    {
      "rubric_id": "caching",
      "rubric_name": "Redis Caching",
      "rubric_type": "numeric",
      "max_score": 30,
      "weight": 1.0,
      "description": "Proper use of Redis for caching"
    },
    {
      "rubric_id": "performance",
      "rubric_name": "Performance",
      "rubric_type": "numeric",
      "max_score": 20,
      "weight": 0.8,
      "description": "Response times meet requirements with caching"
    },
    {
      "rubric_id": "error_handling",
      "rubric_name": "Error Handling",
      "rubric_type": "numeric",
      "max_score": 10,
      "weight": 0.6,
      "description": "Proper error handling and status codes"
    }
  ],

  "metadata": {
    "difficulty": "medium",
    "category": "backend-development",
    "tags": ["python", "flask", "redis", "rest-api", "caching"],
    "estimated_time_minutes": 120
  }
}
