{
  "problem_id": "fullstack-todo-app",
  "problem_name": "Full-Stack Todo Application",
  "description": "Build a complete full-stack todo application with React frontend, Node.js/Express backend, and PostgreSQL database",
  "project_type": "full_stack_web",
  "container_type": "multi-container",

  "containers": [
    {
      "container_id": "database",
      "container_name": "PostgreSQL Database",
      "role": "database",
      "base_image": "postgres:15-alpine",
      "accepts_submission": false,
      "environment": {
        "POSTGRES_DB": "todoapp",
        "POSTGRES_USER": "todouser",
        "POSTGRES_PASSWORD": "todopass"
      },
      "resource_limits": {
        "memory": "256m",
        "cpus": 0.5
      },
      "network_mode": "internal",
      "ports": ["5432"],
      "health_check": {
        "command": "pg_isready -U todouser",
        "interval": 5,
        "timeout": 3,
        "retries": 5
      }
    },
    {
      "container_id": "backend",
      "container_name": "Backend API Server",
      "role": "submission",
      "base_image": "node:18-alpine",
      "accepts_submission": true,
      "submission_package_id": "backend",
      "mount_path": "/workspace/backend",
      "build_steps": [
        {
          "type": "run",
          "command": "apk add --no-cache postgresql-client"
        },
        {
          "type": "workdir",
          "path": "/workspace/backend"
        },
        {
          "type": "copy",
          "source": "package*.json",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "npm ci --only=production"
        },
        {
          "type": "copy",
          "source": ".",
          "destination": "./"
        }
      ],
      "environment": {
        "NODE_ENV": "production",
        "PORT": "3001",
        "DATABASE_URL": "postgresql://todouser:todopass@database:5432/todoapp"
      },
      "resource_limits": {
        "memory": "512m",
        "cpus": 1.0,
        "timeout": 300
      },
      "network_mode": "internal",
      "ports": ["3001"],
      "depends_on": ["database"],
      "command": "npm start",
      "health_check": {
        "command": "wget --no-verbose --tries=1 --spider http://localhost:3001/health || exit 1",
        "interval": 10,
        "timeout": 5,
        "retries": 3
      }
    },
    {
      "container_id": "frontend",
      "container_name": "Frontend React App",
      "role": "submission",
      "base_image": "node:18-alpine",
      "accepts_submission": true,
      "submission_package_id": "frontend",
      "mount_path": "/workspace/frontend",
      "build_steps": [
        {
          "type": "workdir",
          "path": "/workspace/frontend"
        },
        {
          "type": "copy",
          "source": "package*.json",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "npm ci --only=production"
        },
        {
          "type": "copy",
          "source": ".",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "npm run build"
        },
        {
          "type": "run",
          "command": "npm install -g serve"
        }
      ],
      "environment": {
        "NODE_ENV": "production",
        "REACT_APP_API_URL": "http://backend:3001"
      },
      "resource_limits": {
        "memory": "512m",
        "cpus": 1.0
      },
      "network_mode": "internal",
      "ports": ["3000"],
      "depends_on": ["backend"],
      "command": "serve -s build -l 3000"
    },
    {
      "container_id": "tester",
      "container_name": "E2E Test Runner",
      "role": "sidecar",
      "base_image": "node:18-alpine",
      "accepts_submission": false,
      "build_steps": [
        {
          "type": "run",
          "command": "apk add --no-cache chromium"
        },
        {
          "type": "workdir",
          "path": "/workspace/tests"
        },
        {
          "type": "copy",
          "source": ".",
          "destination": "./"
        },
        {
          "type": "run",
          "command": "npm ci"
        }
      ],
      "environment": {
        "FRONTEND_URL": "http://frontend:3000",
        "BACKEND_URL": "http://backend:3001",
        "CHROMIUM_PATH": "/usr/bin/chromium-browser"
      },
      "resource_limits": {
        "memory": "1024m",
        "cpus": 2.0,
        "timeout": 180
      },
      "network_mode": "internal",
      "depends_on": ["frontend", "backend", "database"],
      "command": "npm test"
    }
  ],

  "submission_packages": [
    {
      "package_id": "backend",
      "package_name": "Backend API",
      "target_container_id": "backend",
      "mount_path": "/workspace/backend",
      "required": true
    },
    {
      "package_id": "frontend",
      "package_name": "Frontend Application",
      "target_container_id": "frontend",
      "mount_path": "/workspace/frontend",
      "required": true
    }
  ],

  "resource_limits": {
    "memory": "2g",
    "cpus": 4,
    "timeout": 300
  },

  "rubrics": [
    {
      "rubric_id": "backend_api",
      "rubric_name": "Backend API Functionality",
      "rubric_type": "numeric",
      "max_score": 40,
      "weight": 1.0,
      "description": "All API endpoints work correctly with proper CRUD operations"
    },
    {
      "rubric_id": "frontend_ui",
      "rubric_name": "Frontend UI/UX",
      "rubric_type": "numeric",
      "max_score": 30,
      "weight": 0.8,
      "description": "UI renders correctly and user interactions work as expected"
    },
    {
      "rubric_id": "database_integration",
      "rubric_name": "Database Integration",
      "rubric_type": "numeric",
      "max_score": 20,
      "weight": 0.9,
      "description": "Data persistence works correctly with PostgreSQL"
    },
    {
      "rubric_id": "e2e_tests",
      "rubric_name": "End-to-End Tests",
      "rubric_type": "numeric",
      "max_score": 10,
      "weight": 0.5,
      "description": "Complete user workflows function correctly"
    }
  ],

  "metadata": {
    "difficulty": "hard",
    "category": "full-stack-development",
    "tags": [
      "react",
      "nodejs",
      "express",
      "postgresql",
      "full-stack",
      "docker"
    ],
    "estimated_time_minutes": 240
  }
}
