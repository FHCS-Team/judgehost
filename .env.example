# Judgehost Configuration Example
# Copy to .env and customize

# Node Environment
NODE_ENV=development

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock

# Resource Limits
JUDGEHOST_MAX_WORKERS=3
JUDGEHOST_MAX_MEMORY_MB=8192
JUDGEHOST_MAX_CPU_CORES=8.0
JUDGEHOST_CONTAINER_MAX_MEMORY_MB=4096
JUDGEHOST_CONTAINER_MAX_CPU_CORES=4.0

# Queue Configuration
JUDGEHOST_MAX_QUEUE_SIZE=100
JUDGEHOST_RATE_LIMIT_ENABLED=false

# File System Paths
JUDGEHOST_WORK_DIR=/tmp/judgehost
JUDGEHOST_PROBLEMS_DIR=/var/lib/judgehost/problems
JUDGEHOST_SUBMISSIONS_DIR=/var/lib/judgehost/submissions
JUDGEHOST_RESULTS_DIR=/var/lib/judgehost/results
JUDGEHOST_LOGS_DIR=/var/log/judgehost

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0
API_CORS_ENABLED=true
API_CORS_ORIGIN=*
API_AUTH_ENABLED=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CONSOLE_ENABLED=true

# Docker Settings
CLEANUP_CONTAINERS_AFTER_EVAL=true
CLEANUP_IMAGES_OLDER_THAN_DAYS=7

# Git Integration
GIT_DEFAULT_TIMEOUT_SECONDS=300
GIT_MAX_REPO_SIZE_MB=100
GIT_SHALLOW_CLONE=true

# Debug Mode
DEBUG_MODE=false
