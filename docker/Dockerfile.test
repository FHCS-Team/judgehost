# Dockerfile.busybox-test: Minimal test for universal entrypoint & hooks system
FROM busybox:latest

# Create workdir and copy tools
WORKDIR /work
COPY tools /work/tools
COPY hooks /work/hooks
COPY universal_entrypoint.sh /work/entrypoint.sh

# Make scripts executable
RUN chmod +x /work/entrypoint.sh \
    && find /work/tools -type f -exec chmod +x {} + \
    && find /work/hooks -type f -name "*.sh" -exec chmod +x {} +

ENV SHOW_LOGS=1

ENTRYPOINT ["/work/entrypoint.sh"]
CMD ["echo", "Hello from BusyBox!"]
